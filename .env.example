# Скопируй этот файл в .env.local и заполни значения

# Backend API URL
NEXT_PUBLIC_API_URL=https://your-api-url.com

# 2GIS карта
NEXT_PUBLIC_2GIS_API_KEY=

# WhatsApp OTP
NEXT_PUBLIC_WHATSAPP_TOKEN=

# Название приложения
NEXT_PUBLIC_APP_NAME=Companion Admin

# JWT секрет — сгенерируй: openssl rand -base64 32
JWT_SECRET=

# Начальный пароль для всех администраторов при первом запуске
# После входа каждый меняет пароль сам через страницу Администраторы
INITIAL_ADMIN_PASSWORD=
