# Скопируй этот файл в .env.local и заполни значения

# Backend API URL (auth service)
NEXT_PUBLIC_API_URL=https://companion.kopir.uk/api/auth

# Config Service API
CONFIG_API_URL=https://companion.kopir.uk/api/config

# 2GIS карта (берётся с бэка автоматически, fallback)
NEXT_PUBLIC_2GIS_API_KEY=

# Timezone
APP_TIMEZONE=Asia/Almaty

# Название приложения
NEXT_PUBLIC_APP_NAME=Companion Admin

# JWT секрет — ДОЛЖЕН совпадать с JWT_SECRET_KEY в auth-service
JWT_SECRET=
